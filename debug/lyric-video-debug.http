### 第三步 Prompt 2：Claude Opus 4.5 分镜 + 图片/视频 Prompt
# 先跑第一层 analyze，再跑第二步 Prompt 1，然后跑这里。
# 这个接口不需要登录，不写数据库，只返回 scenes JSON。
# @name debugGenerateStoryboardScenesWithOpus
POST {{baseUrl}}/api/debug/lyric-videos/llm/storyboard-scenes
Content-Type: application/json

{
  "model": "claude-opus-4-5",
  "songAnalysis": {{debugAnalyzeSongWithOpus.response.body.$.data.songAnalysis}},
  "preprocess": {{debugAnalyzeLyricVideoAudio.response.body.$.data.preprocess}}
}
